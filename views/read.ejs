<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://kit.fontawesome.com/295da72d04.js" crossorigin="anonymous"></script>
</head>

<body>
    <i class="fas fa-bars" id="btn"></i>
    <div class="heading">
        <h1>Students</h1>
    </div>
    <div class="search_container">
        <input type="search" placeholder="       Search For Students" class="search-bar">
        <i class="fa-solid fa-magnifying-glass" id="search_Icon"></i>
    </div>
    <div class="btn"><button class="Add_New"><a href="/" class="ab">+ Add new </a><br><br>
            <a href="/attendance" class="Attendance">Attendance</a></button></div>
    <!-- <div class="btn"><button class="Add_New"><a href="http://127.0.0.1:5500/index.html">Attendance</a></button></div> -->
    <table>
        <tr>

            <th>Name</th>
            <th>PRN</th>
            <th>Place</th>
            <th>Remove</th>
        </tr>





        <% users.forEach(function(user){%>
            <tr>

                <td>
                    <%=user.name%>
                </td>
                <td>
                    <%=user.PRN%>
                </td>
                <td>
                    <%=user.place%>
                </td>
                <td><a href="/delete/<%=user._id%>"><i class="fa-solid fa-trash"></i></a></td>
            </tr>
            <%}) %>

    </table>
</body>

</html>